<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Comment</title>

    <link rel="stylesheet" href="/style.css">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>

<div class="container">

    <!-- Header -->

    <div class="top-bar">

        <div>

            <h1 class="title">
                ✏️ Edit Comment
            </h1>

            <p class="subtitle">
                Update your comment below.
            </p>

        </div>

        <a href="/comments" class="btn secondary">

            <i class="fa-solid fa-arrow-left"></i>

            Back

        </a>

    </div>

    <!-- Edit Form -->

    <div class="card">

        <form
            action="/comments/<%= comment._id %>?_method=PATCH"
            method="POST">

            <label>

                <i class="fa-solid fa-user"></i>

                Username

            </label>

            <input
                type="text"
                name="user"
                value="<%= comment.user %>"
                required
            >

            <label>

                <i class="fa-solid fa-comment-dots"></i>

                Comment

            </label>

            <textarea
                name="text"
                required><%= comment.text %></textarea>

            <br>

            <div class="badge">

                ❤️ <%= comment.likes %> Likes

            </div>

            <div
            style="
            display:flex;
            gap:15px;
            margin-top:25px;
            flex-wrap:wrap;
            ">

                <button class="btn warning">

                    <i class="fa-solid fa-floppy-disk"></i>

                    Update

                </button>

                <a
                href="/comments"
                class="btn primary">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>

</body>
</html>