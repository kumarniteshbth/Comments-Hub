<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comment Details</title>

    <link rel="stylesheet" href="/style.css">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>

<div class="container">

    <!-- Header -->

    <div class="top-bar">

        <div>

            <h1 class="title">
                💬 Comment Details
            </h1>

            <p class="subtitle">
                Read and interact with this comment.
            </p>

        </div>

        <a href="/comments" class="btn secondary">

            <i class="fa-solid fa-arrow-left"></i>

            Back

        </a>

    </div>



    <!-- Comment Card -->

    <div class="card center">

        <div class="avatar" style="margin:auto;margin-bottom:20px;">

            <%= comment.user.charAt(0).toUpperCase() %>

        </div>

        <div class="badge">

            👤 <%= comment.user %>

        </div>

        <h2 style="margin:20px 0;">

            "<%= comment.text %>"

        </h2>

        <p style="margin-bottom:25px;">

            ❤️ <strong><%= comment.likes %></strong> Likes

        </p>



        <div
        style="display:flex;
        justify-content:center;
        gap:15px;
        flex-wrap:wrap;">

            <!-- Like -->

            <form
            action="/comments/<%= comment._id %>/like?_method=PATCH"
            method="POST">

                <button class="btn like-btn">

                    ❤️ Like

                </button>

            </form>

            <!-- Edit -->

            <a
            href="/comments/<%= comment._id %>/edit"
            class="btn warning">

                <i class="fa-solid fa-pen"></i>

                Edit

            </a>

            <!-- Delete -->

            <form
            action="/comments/<%= comment._id %>?_method=DELETE"
            method="POST">

                <button class="btn danger">

                    <i class="fa-solid fa-trash"></i>

                    Delete

                </button>

            </form>

            <!-- All Comments -->

            <a
            href="/comments"
            class="btn primary">

                <i class="fa-solid fa-comments"></i>

                All Comments

            </a>

        </div>

    </div>

</div>

</body>
</html>